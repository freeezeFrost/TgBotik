BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1
ANALYSIS_TIMEOUT_SECONDS=45
ANALYSIS_QUEUE_TIMEOUT_SECONDS=3
LOG_LEVEL=INFO
MAX_DIALOG_MESSAGES=150
MAX_ANALYSIS_TEXT_CHARS=14000
MESSAGE_RATE_LIMIT_WINDOW_SECONDS=10
MESSAGE_RATE_LIMIT_COUNT=12
MESSAGE_RATE_LIMIT_NOTICE_COOLDOWN=5
ANALYSIS_COOLDOWN_SECONDS=15
MAX_CONCURRENT_ANALYSES=2
